    "bcryptjs": "^2.4.3",
    "bullmq": "^5.26.2",
    "date-fns": "^4.1.0",
    "docx": "^9.0.2",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "multer": "^1.4.5-lts.1",
    "next": "^15.5.15",
    "next-auth": "^4.24.11",
    "otplib": "^13.4.0",
    "papaparse": "^5.4.1",
    "pdf-lib": "^1.17.1",
